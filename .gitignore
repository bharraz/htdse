# Ignore Python cache and build artifacts
__pycache__/
*.py[cod]
*.so
*.pyd
*.pyo

.claude/*

# Ignore setuptools/distribution metadata
*.egg-info/

# Ignore HDF5 files
*.h5
*.hdf5
*.he5

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore virtual environments
.venv/
venv/
ENV/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore test and coverage outputs
htmlcov/
.coverage
.tox/

# Ignore user/editor files
*.swp
*.swo
*.bak
*.tmp
.idea/
.vscode/
